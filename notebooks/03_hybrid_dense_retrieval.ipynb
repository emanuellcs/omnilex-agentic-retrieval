{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Omnilex: Hybrid Retrieval Submission
",
    "This notebook implements the primary pipeline for the LLM Agentic Legal Information Retrieval competition.
",
    "
",
    "### Pipeline Stages:
",
    "1. **Translation**: English query to German (MarianMT).
",
    "2. **Hybrid Retrieval**: BM25 + Dense (FAISS) on both laws and courts corpora.
",
    "3. **RRF Merging**: Reciprocal Rank Fusion to combine results.
",
    "4. **Graph Expansion**: Personalized PageRank on the citation co-occurrence graph.
",
    "5. **Reranking**: Cross-Encoder scoring of all candidates.
",
    "6. **Thresholding & Grounding**: Final selection and hard grounding against corpus."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os
",
    "import sys
",
    "import json
",
    "import pandas as pd
",
    "import numpy as np
",
    "from pathlib import Path
",
    "from tqdm.auto import tqdm
",
    "
",
    "# Environment Detection
",
    "IS_KAGGLE = "KAGGLE_KERNEL_RUN_TYPE" in os.environ
",
    "
",
    "if IS_KAGGLE:
",
    "    sys.path.append("/kaggle/input/omnilex-src/src")
",
    "    DATA_DIR = Path("/kaggle/input/omnilex-data/raw")
",
    "    PROCESSED_DIR = Path("/kaggle/input/omnilex-indices")
",
    "    CONFIG_DIR = Path("/kaggle/input/omnilex-config")
",
    "else:
",
    "    # Local development paths
",
    "    PROJECT_ROOT = Path("..")
",
    "    sys.path.append(str(PROJECT_ROOT / "src"))
",
    "    DATA_DIR = PROJECT_ROOT / "data" / "raw"
",
    "    PROCESSED_DIR = PROJECT_ROOT / "data" / "processed"
",
    "    CONFIG_DIR = PROJECT_ROOT / "config"
",
    "
",
    "from omnilex.retrieval.bm25_index import BM25Index
",
    "from omnilex.retrieval.dense_retrieval import FAISSIndex, MultilingualEmbedder
",
    "from omnilex.retrieval.translator import QueryTranslator
",
    "from omnilex.retrieval.citation_graph import CitationCooccurrenceGraph
",
    "from omnilex.retrieval.reranker import CrossEncoderReranker
",
    "from omnilex.pipeline.hybrid_retriever import HybridRetriever
",
    "from omnilex.pipeline.full_pipeline import FullPipeline
",
    "from omnilex.evaluation.metrics import macro_f1"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Configuration and Paths"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(CONFIG_DIR / "pipeline_config.json", "r") as f:
",
    "    config = json.load(f)
",
    "
",
    "print("Pipeline Configuration:")
",
    "print(json.dumps(config, indent=2))
",
    "
",
    "LAWS_CSV = DATA_DIR / "laws_de.csv"
",
    "COURTS_CSV = DATA_DIR / "court_considerations.csv"
",
    "VAL_CSV = DATA_DIR / "val.csv"
",
    "TEST_CSV = DATA_DIR / "test.csv""
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load Indices and Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print("Loading indices...")
",
    "laws_bm25 = BM25Index.load(PROCESSED_DIR / "laws_index.pkl")
",
    "courts_bm25 = BM25Index.load(PROCESSED_DIR / "courts_index.pkl")
",
    "laws_faiss = FAISSIndex.load(PROCESSED_DIR / "laws_faiss")
",
    "courts_faiss = FAISSIndex.load(PROCESSED_DIR / "courts_faiss")
",
    "citation_graph = CitationCooccurrenceGraph.load(PROCESSED_DIR / "citation_graph.pkl")
",
    "
",
    "print("Loading models...")
",
    "embedder = MultilingualEmbedder(model_name=config["embedder_model"])
",
    "translator = QueryTranslator(model_name=config["translator_model"])
",
    "reranker = CrossEncoderReranker(model_name=config["reranker_model"])
",
    "
",
    "print("Building grounding set...")
",
    "# Building grounding set from indices to avoid loading full CSVs if possible
",
    "laws_citations = [d["citation"] for d in laws_faiss.documents]
",
    "courts_citations = [d["citation"] for d in courts_faiss.documents]
",
    "corpus_citation_set = set(laws_citations) | set(courts_citations)
",
    "print(f"Valid citations in corpus: {len(corpus_citation_set)}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Initialize Pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "hybrid_retriever = HybridRetriever(
",
    "    laws_bm25, courts_bm25, laws_faiss, courts_faiss,
",
    "    embedder, translator, citation_graph, corpus_citation_set
",
    ")
",
    "
",
    "pipeline = FullPipeline(
",
    "    hybrid_retriever, reranker, 
",
    "    threshold=config["threshold"], 
",
    "    corpus_citation_set=corpus_citation_set
",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Validation (Optional)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if VAL_CSV.exists():
",
    "    print("Running validation...")
",
    "    val_df = pd.read_csv(VAL_CSV)
",
    "    val_queries = val_df["query"].tolist()
",
    "    val_gold = [c.split(";") if pd.notna(c) else [] for c in val_df["gold_citations"].tolist()]
",
    "    
",
    "    val_predictions = pipeline.run_batch(val_queries)
",
    "    
",
    "    metrics = macro_f1(val_predictions, val_gold)
",
    "    print("
Validation Results:")
",
    "    for m, v in metrics.items():
",
    "        print(f"{m}: {v:.4f}")
",
    "else:
",
    "    print("Validation set not found. Skipping.")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Inference on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print("Running inference on test set...")
",
    "test_df = pd.read_csv(TEST_CSV)
",
    "test_queries = test_df["query"].tolist()
",
    "
",
    "test_predictions = pipeline.run_batch(test_queries)
",
    "
",
    "# Format for submission
",
    "submission_df = pd.DataFrame({
",
    "    "query_id": test_df["query_id"],
",
    "    "predicted_citations": [";".join(c) for c in test_predictions]
",
    "})
",
    "
",
    "submission_df.to_csv("submission.csv", index=False)
",
    "print("
Submission saved to submission.csv")
",
    "submission_df.head()"
   ]
  }
 ],
