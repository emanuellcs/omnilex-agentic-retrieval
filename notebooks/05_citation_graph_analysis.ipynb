 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Omnilex: Citation Graph Analysis
",
    "Exploratory analysis of the structural priors captured in 30 years of Federal Court decisions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys
",
    "import pandas as pd
",
    "import networkx as nx
",
    "import matplotlib.pyplot as plt
",
    "from pathlib import Path
",
    "
",
    "PROJECT_ROOT = Path("..")
",
    "sys.path.append(str(PROJECT_ROOT / "src"))
",
    "
",
    "from omnilex.retrieval.citation_graph import CitationCooccurrenceGraph
",
    "
",
    "GRAPH_PATH = PROJECT_ROOT / "data" / "processed" / "citation_graph.pkl"
",
    "graph_obj = CitationCooccurrenceGraph.load(GRAPH_PATH)
",
    "G = graph_obj.graph"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Graph Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f"Nodes: {G.number_of_nodes()}")
",
    "print(f"Edges: {G.number_of_edges()}")
",
    "print(f"Density: {nx.density(G):.6f}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Degree Distribution
",
    "Identifying the most "authoritative" citations."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "degrees = dict(G.degree())
",
    "sorted_degrees = sorted(degrees.items(), key=lambda x: x[1], reverse=True)
",
    "
",
    "print("Top 20 Most Connected Citations:")
",
    "for cit, deg in sorted_degrees[:20]:
",
    "    print(f"{cit}: {deg}")
",
    "
",
    "plt.figure(figsize=(10, 5))
",
    "plt.hist(degrees.values(), bins=50, log=True)
",
    "plt.title("Degree Distribution (Log Scale)")
",
    "plt.xlabel("Degree")
",
    "plt.ylabel("Frequency")
",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Personalized PageRank Expansion Example
",
    "Simulating how the pipeline expands a query."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "seed = ["Art. 36 BV"] # Freedom of expression / restriction of fundamental rights
",
    "expansion = graph_obj.personalized_pagerank(seed, top_k=10)
",
    "
",
    "print(f"Expansion for seed {seed}:")
",
    "for cit, score in expansion:
",
    "    print(f"- {cit} (PageRank: {score:.4f})")"
   ]
  }
 ],
